# SUT URLs
BE_URL=http://localhost:3000
FE_URL=http://localhost:5173

# Test configuration
BROWSER=chrome-headless
RUN_TYPE=nightly

# Report output directories
LOG_DIR=reports/logs
SCREENSHOT_DIR=reports/screenshots

# Performance test configuration
PERF_SEEDED_USER_EMAIL=your_seeded_user_email
PERF_SEEDED_USER_PASSWORD=your_seeded_user_password
PERFORMANCE_RUN_TIME=2m
PERFORMANCE_USERS=20
PERFORMANCE_SPAWN_RATE=5

# JUnit report paths
UNIT_JUNIT_PATH=reports/jest-junit.xml
API_JUNIT_PATH=reports/api-junit.xml
E2E_JUNIT_PATH=reports/e2e-junit.xml

# Performance report paths
PERF_CSV_STATS_PATH=reports/performance/results_stats.csv
PERF_CSV_FAILURES_PATH=reports/performance/results_failures.csv

# Build metadata (auto-injected by Jenkins pipeline, set manually for local runs)
TIMESTAMP=1781654400000
BUILD_NUMBER=local_run
BUILD_URL=http://localhost:8080/job/akiro
BRANCH=master
AUTHOR=your_name
HOST=your_hostname

# InfluxDB
INFLUX_HOST=http://localhost:8181
INFLUX_TOKEN=your_influxdb_token
INFLUX_DATABASE=devtest_metrics
